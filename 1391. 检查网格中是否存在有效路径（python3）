from typing import List
from collections import deque

class Solution:
    def hasValidPath(self, grid: List[List[int]]) -> bool:
        m, n = len(grid), len(grid[0])
        dr = [-1, 1, 0, 0]
        dc = [0, 0, -1, 1]
        opp = [1, 0, 3, 2] 
        conn = [
            # type 1: 左右
            [-1, -1, 3, 2],
            # type 2: 上下
            [1, 0, -1, -1],
            # type 3: 左下
            [-1, 2, 1, -1],
            # type 4: 右下
            [-1, 3, -1, 1],
            # type 5: 左上
            [2, -1, 0, -1],
            # type 6: 右上
            [3, -1, -1, 0]
        ]

        visited = [[[False]*4 for _ in range(n)] for _ in range(m)]

        q = deque()
        # 起点: 出口方向枚举该形状的所有出口
        start_type = grid[0][0]
        for out_dir in range(4):
            if out_dir in conn[start_type-1]:
                nr, nc = dr[out_dir], dc[out_dir]
                if 0 <= nr < m and 0 <= nc < n:
                    in_dir_next = opp[out_dir]
                    if conn[grid[nr][nc]-1][in_dir_next] != -1:
                        visited[nr][nc][in_dir_next] = True
                        q.append((nr, nc, in_dir_next))
        if m == 1 and n == 1:
            return True

        while q:
            r, c, from_dir = q.popleft()
            if r == m-1 and c == n-1:
                return True
            t = grid[r][c]
            out_dir = conn[t-1][from_dir]  # 唯一出口
            nr, nc = r + dr[out_dir], c + dc[out_dir]
            if 0 <= nr < m and 0 <= nc < n:
                need_in = opp[out_dir]
                if conn[grid[nr][nc]-1][need_in] != -1 and not visited[nr][nc][need_in]:
                    visited[nr][nc][need_in] = True
                    q.append((nr, nc, need_in))
        return False
