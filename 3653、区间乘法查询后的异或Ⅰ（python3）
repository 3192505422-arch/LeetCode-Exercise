class Solution:
    def xorAfterQueries(self, nums, queries):
        MOD = 10**9 + 7
        # 复制数组，避免修改原数组
        arr = nums.copy()
        
        for li, ri, ki, vi in queries:
            idx = li
            while idx <= ri:
                arr[idx] = (arr[idx] * vi) % MOD
                idx += ki
        
        # 计算所有元素的异或
        result = 0
        for val in arr:
            result ^= val
        return result
