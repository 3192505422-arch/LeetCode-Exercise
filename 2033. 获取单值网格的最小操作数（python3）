from typing import List

class Solution:
    def minOperations(self, grid: List[List[int]], x: int) -> int:
        m, n = len(grid), len(grid[0])
        flat = []
        r0 = grid[0][0] % x
        for i in range(m):
            for j in range(n):
                if grid[i][j] % x != r0:
                    return -1
                flat.append(grid[i][j] // x)
        
        flat.sort()
        median = flat[len(flat) // 2]
        return sum(abs(num - median) for num in flat)
